# ── Backend (servizio Node) ────────────────────────────────────────────
# URL del webhook n8n (obbligatorio, MAI esposto al frontend)
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/your-webhook-id

# Origini ammesse per CORS (default: *). Su Railway impostalo all'URL del frontend.
ALLOWED_ORIGINS=*

# ── Frontend (build-time) ──────────────────────────────────────────────
# URL pubblico del backend. Lascia vuoto in locale (nginx fa da proxy).
# Su Railway impostalo all'URL pubblico del servizio backend.
VITE_API_URL=
