# ── Backend ────────────────────────────────────────────────────────────
# URL del webhook n8n (obbligatorio, MAI esposto al frontend)
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/your-webhook-id

# Origini ammesse per CORS. Su Railway metti l'URL del frontend.
ALLOWED_ORIGINS=*

# ── Frontend (build-time) ──────────────────────────────────────────────
# URL pubblico del backend.
# Locale (docker-compose): http://localhost:8081  ← default se vuoto
# Railway: https://<backend-service>.up.railway.app
VITE_API_URL=http://localhost:8081
